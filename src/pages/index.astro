  canonical: "https://numbkit.com/",
  lang: "en",
  slug: "home",
};
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Numbkit",
  "url": "https://numbkit.com/",
  "description": "Free crypto and freelance finance calculators",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://numbkit.com/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
